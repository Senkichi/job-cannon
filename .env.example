# Job Cannon — Environment Variables
# Copy this file to .env and fill in your keys.
# The app uses python-dotenv to load these automatically.

# Required: Anthropic API key for AI scoring and resume generation
# Get yours at: https://console.anthropic.com/settings/keys
# Named JF_ to prevent Claude Code from detecting and using it as its own auth
JF_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Flask session secret key
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a dev-only default is used (not suitable for shared networks)
# FLASK_SECRET_KEY=your-secret-key-here

# --- Alternative Model Providers (all optional) ---
# Used by eval_provider.py and the multi-provider scoring pipeline.
# Each provider adapter reads its key from the env var below.

# SambaNova Cloud — https://cloud.sambanova.ai
# SAMBANOVA_API_KEY=your-key-here

# OpenRouter — https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Google Gemini — https://ai.google.dev
# GEMINI_API_KEY=your-key-here

# Groq — https://console.groq.com
# GROQ_API_KEY=gsk_your-key-here

# Cerebras — https://cloud.cerebras.ai
# CEREBRAS_API_KEY=your-key-here

# Mistral — https://console.mistral.ai
# MISTRAL_API_KEY=your-key-here

# Cohere — https://dashboard.cohere.com
# CO_API_KEY=your-key-here
